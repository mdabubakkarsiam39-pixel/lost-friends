{
  "name": "lost-friends-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "bun --watch src/app.ts",
    "build": "bun build src/app.ts --outdir dist --target bun",
    "start": "bun dist/app.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "bun run src/scripts/generate.ts",
    "db:push": "bun run src/scripts/push.ts"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.0",
    "svix": "^1.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.56.0",
    "typescript": "5.4.5"
    "web-push": "^3.6.0"
  }
}